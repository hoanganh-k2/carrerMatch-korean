datasource db {
  provider   = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

// 1. USER DATASET - Thêm cấu trúc năng lực tiếng Hàn (TOPIK)
enum Role {
  candidate
  recruiter
  admin
}

enum JobType {
  fulltime
  parttime
  remote
  hybrid
}

enum TopikLevel {
  TOPIK_I_LEVEL_1
  TOPIK_I_LEVEL_2
  TOPIK_II_LEVEL_3
  TOPIK_II_LEVEL_4
  TOPIK_II_LEVEL_5
  TOPIK_II_LEVEL_6
  NONE
}

model JobUser {
  userId            String            @id @default(uuid()) @map("user_id")
  role              Role              @default(candidate)
  fullName          String            @map("full_name")
  
  // Khối năng lực Tiếng Hàn & Kỹ thuật
  topikLevel        TopikLevel        @default(NONE) @map("topik_level")
  koreanScore       Int?              @map("korean_score") // Điểm thi cụ thể (Ví dụ: 185/300)
  isBrSE            Boolean           @default(false) @map("is_brse") // Có định hướng Kỹ sư cầu nối hay không
  skillsVector      String? @map("skills_vector") // Embedding tổng hợp cả IT + Tiếng Hàn
  skillsExtracted   String[]          @map("skills_extracted") // ['React', 'Spring Boot', 'Korean Translation', 'Business Communication']
  
  yearsExperience   Float?            @map("years_experience")
  desiredSalaryMin  Int?              @map("desired_salary_min")
  desiredSalaryMax  Int?              @map("desired_salary_max")
  jobTypePrefs      JobType           @default(fulltime) @map("job_type_prefs")
  locationPrefs     String[]          @map("location_prefs") // ['Hà Nội', 'Seoul', 'Remote']
  openToWork        Boolean           @default(true) @map("open_to_work")
  profileCompleteness Float           @default(0.0) @map("profile_completeness")
  
  applications      JobApplication[]
  events            CareerEvent[]

  @@map("job_users")
}

// 2. CORE-DOMAIN DATASET - Tin tuyển dụng (Hỗ trợ đa ngôn ngữ Kor/Vie)
enum JobStatus {
  active
  paused
  filled
  expired
}

model JobPosting {
  jobId               String           @id @default(uuid()) @map("job_id")
  companyId           String           @map("company_id")
  
  // Tiêu đề và JD bằng tiếng Hàn hoặc tiếng Việt
  title               String           // Ví dụ: [Hà Nội] Tuyển dụng BrSE (Tiếng Hàn TOPIK 5 trở lên)
  description         String           @db.Text // Mô tả chi tiết các tác vụ dịch thuật, quản lý dự án, coding
  jdEmbedding         String? @map("jd_embedding") // Embedding lưu thông tin ngữ nghĩa đa ngôn ngữ
  
  // Yêu cầu ngôn ngữ & Kỹ thuật cốt lõi
  minTopikRequired    TopikLevel       @default(NONE) @map("min_topik_required")
  requiredSkills      String[]         @map("required_skills") // ['Java', 'Korean Translation', 'Jira']
  preferredSkills     String[]         @map("preferred_skills")
  
  salaryMin           Int?             @map("salary_min")
  salaryMax           Int?             @map("salary_max")
  jobType             JobType          @map("job_type")
  experienceYearsMin  Float            @default(0) @map("experience_years_min")
  location            String
  applicationDeadline DateTime         @map("application_deadline")
  status              JobStatus        @default(active)
  viewsCount          Int              @default(0) @map("views_count")
  applyCount          Int              @default(0) @map("apply_count")

  applications        JobApplication[]
  events              CareerEvent[]

  @@map("job_postings")
}

// 3. QUALITY & FEEDBACK DATASET - Đánh giá & Matching hồ sơ
enum ApplicationStatus {
  applied
  screening
  interview
  offer
  rejected
  accepted
}

model JobApplication {
  applicationId      String            @id @default(uuid()) @map("application_id")
  jobId              String            @map("job_id")
  candidateId        String            @map("candidate_id")
  matchScore         Float             @map("match_score") // Điểm matching AI
  matchBreakdownJson Json              @map("match_breakdown_json") // Phân rã điểm: { "it_skill": 0.8, "korean_skill": 0.9, "experience": 0.7 }
  status             ApplicationStatus @default(applied)
  coverLetter        String?           @map("cover_letter") // Có thể viết bằng tiếng Hàn
  recruiterNote      String?           @map("recruiter_note")
  recruiterRating    Int?              @map("recruiter_rating")
  stageTimestamps    Json              @map("stage_timestamps")

  job                JobPosting        @relation(fields: [jobId], references: [jobId])
  candidate          JobUser           @relation(fields: [candidateId], references: [userId])

  @@map("job_applications")
}

// 4. TAXONOMY & RELATION DATASET - Chuẩn hóa từ điển kỹ năng IT & Ngôn ngữ
model SkillTaxonomy {
  skillId         String            @id @default(uuid()) @map("skill_id")
  skillName       String            @unique @map("skill_name") // 'Cơ sở dữ liệu', '한국어', 'Interpretation'
  skillEmbedding  String? @map("skill_embedding") 
  category        String            // 'Programming', 'Language', 'Methodology'
  parentSkillId   String?           @map("parent_skill_id")
  aliases         String[]          @map("aliases") // ['Tiếng Hàn thương mại', 'Business Korean', '비즈니스 한국어']
  demandScore     Float             @default(0.0) @map("demand_score")

  parent          SkillTaxonomy?    @relation("SkillHierarchy", fields: [parentSkillId], references: [skillId])
  subSkills       SkillTaxonomy[]   @relation("SkillHierarchy")

  @@map("skill_taxonomy")
}

// 5. METADATA & ANALYTICS DATASET - Log hành vi tìm kiếm
enum EventType {
  view_job
  search
  apply
  save
  profile_update
  skill_add
}

model CareerEvent {
  eventId           BigInt            @id @default(autoincrement()) @map("event_id")
  userId            String            @map("user_id")
  eventType         EventType         @map("event_type")
  jobId             String?           @map("job_id")
  searchQuery       String?           @map("search_query") // Thống kê xem user hay tìm bằng từ khóa "BrSE", "Tiếng Hàn" hay "Cầu nối"
  searchFiltersJson Json?             @map("search_filters_json")
  clickPosition     Int?              @map("click_position")
  timeSpentSeconds  Int?              @map("time_spent_seconds")
  deviceType        String?           @map("device_type")
  createdAt         DateTime          @default(now()) @map("created_at")

  user              JobUser           @relation(fields: [userId], references: [userId])
  job               JobPosting?       @relation(fields: [jobId], references: [jobId])

  @@map("career_events")
}