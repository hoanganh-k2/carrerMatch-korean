datasource db {
  provider   = "postgresql"
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "fullTextSearchPostgres"]
}

// ==================== ENUMS ====================

enum Role {
  candidate
  recruiter
  admin
}

enum JobType {
  fulltime
  parttime
  remote
  hybrid
}

enum TopikLevel {
  TOPIK_I_LEVEL_1
  TOPIK_I_LEVEL_2
  TOPIK_II_LEVEL_3
  TOPIK_II_LEVEL_4
  TOPIK_II_LEVEL_5
  TOPIK_II_LEVEL_6
  NONE
}

enum JobStatus {
  active
  paused
  filled
  expired
}

enum ApplicationStatus {
  applied
  screening
  interview
  offer
  rejected
  accepted
}

enum EventType {
  view_job
  search
  apply
  save
  profile_update
  skill_add
}

// ==================== 0. AUTH - Tài khoản xác thực ====================

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(candidate)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations - một User có thể là candidate (JobUser) hoặc recruiter (Company)
  jobUser      JobUser?
  company      Company?
  userPermissions UserPermission[]
  notifications   Notification[]
  savedJobs       SavedJob[]
  companyReviews  CompanyReview[]
  subscriptions   Subscription[]

  @@map("users")
}

// ==================== 1. USER DATASET - Hồ sơ ứng viên ====================

model JobUser {
  userId            String            @id @map("user_id") // = User.id (FK)
  fullName          String            @map("full_name")

  // Khối năng lực Tiếng Hàn & Kỹ thuật
  topikLevel        TopikLevel        @default(NONE) @map("topik_level")
  koreanScore       Int?              @map("korean_score")
  isBrSE            Boolean           @default(false) @map("is_brse")
  skillsVector      String?           @map("skills_vector")
  skillsExtracted   String[]          @map("skills_extracted")

  yearsExperience   Float?            @map("years_experience")
  desiredSalaryMin  Int?              @map("desired_salary_min")
  desiredSalaryMax  Int?              @map("desired_salary_max")
  jobTypePrefs      JobType           @default(fulltime) @map("job_type_prefs")
  locationPrefs     String[]          @map("location_prefs")
  openToWork        Boolean           @default(true) @map("open_to_work")
  profileCompleteness Float           @default(0.0) @map("profile_completeness")

  // Relations
  user              User              @relation(fields: [userId], references: [id])
  applications      JobApplication[]
  events            CareerEvent[]
  resumes           Resume[]

  @@map("job_users")
}

// ==================== 2. COMPANY - Hồ sơ nhà tuyển dụng ====================

model Company {
  companyId    String   @id @default(uuid()) @map("company_id")
  userId       String   @unique @map("user_id") // recruiter account
  companyName  String   @map("company_name")
  logoUrl      String?  @map("logo_url")
  website      String?
  industry     String?
  companySize  String?  @map("company_size") // "1-50", "51-200", "201-500", "500+"
  description  String?  @db.Text
  location     String?
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  user         User         @relation(fields: [userId], references: [id])
  jobPostings  JobPosting[]
  reviews      CompanyReview[]

  @@map("companies")
}

// ==================== 3. RESUME - CV chi tiết ứng viên ====================

model Resume {
  resumeId       String   @id @default(uuid()) @map("resume_id")
  userId         String   @map("user_id")
  title          String   // "CV BrSE - Nguyễn Văn A"
  summary        String?  @db.Text
  fileUrl        String?  @map("file_url")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Chi tiết CV
  jobUser        JobUser          @relation(fields: [userId], references: [userId])
  experiences    WorkExperience[]
  educations     Education[]
  certifications Certification[]

  @@map("resumes")
}

model WorkExperience {
  id          String    @id @default(uuid())
  resumeId    String    @map("resume_id")
  company     String
  position    String
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  isCurrent   Boolean   @default(false) @map("is_current")
  description String?   @db.Text

  resume      Resume    @relation(fields: [resumeId], references: [resumeId])

  @@map("work_experiences")
}

model Education {
  id          String  @id @default(uuid())
  resumeId    String  @map("resume_id")
  school      String
  degree      String  // "Đại học", "Thạc sĩ"
  major       String
  startYear   Int     @map("start_year")
  endYear     Int?    @map("end_year")

  resume      Resume  @relation(fields: [resumeId], references: [resumeId])

  @@map("educations")
}

model Certification {
  id        String    @id @default(uuid())
  resumeId  String    @map("resume_id")
  name      String    // "TOPIK II Level 5"
  issuer    String?
  issuedAt  DateTime? @map("issued_at")
  expiresAt DateTime? @map("expires_at")

  resume    Resume    @relation(fields: [resumeId], references: [resumeId])

  @@map("certifications")
}

// ==================== 4. CORE DOMAIN - Tin tuyển dụng ====================

model JobPosting {
  jobId               String           @id @default(uuid()) @map("job_id")
  companyId           String           @map("company_id")

  title               String
  description         String           @db.Text
  jdEmbedding         String?          @map("jd_embedding")

  minTopikRequired    TopikLevel       @default(NONE) @map("min_topik_required")
  requiredSkills      String[]         @map("required_skills")
  preferredSkills     String[]         @map("preferred_skills")

  salaryMin           Int?             @map("salary_min")
  salaryMax           Int?             @map("salary_max")
  jobType             JobType          @map("job_type")
  experienceYearsMin  Float            @default(0) @map("experience_years_min")
  location            String
  applicationDeadline DateTime         @map("application_deadline")
  status              JobStatus        @default(active)
  viewsCount          Int              @default(0) @map("views_count")
  applyCount          Int              @default(0) @map("apply_count")
  createdAt           DateTime         @default(now()) @map("created_at")

  // Relations
  company             Company?         @relation(fields: [companyId], references: [companyId])
  applications        JobApplication[]
  events              CareerEvent[]
  savedByUsers        SavedJob[]

  @@map("job_postings")
}

// ==================== 5. QUALITY & FEEDBACK - Đơn ứng tuyển ====================

model JobApplication {
  applicationId      String            @id @default(uuid()) @map("application_id")
  jobId              String            @map("job_id")
  candidateId        String            @map("candidate_id")
  resumeId           String?           @map("resume_id") // CV đính kèm
  matchScore         Float             @map("match_score")
  matchBreakdownJson Json              @map("match_breakdown_json")
  status             ApplicationStatus @default(applied)
  coverLetter        String?           @map("cover_letter")
  recruiterNote      String?           @map("recruiter_note")
  recruiterRating    Int?              @map("recruiter_rating")
  stageTimestamps    Json              @map("stage_timestamps")

  job                JobPosting        @relation(fields: [jobId], references: [jobId])
  candidate          JobUser           @relation(fields: [candidateId], references: [userId])
  interviews         Interview[]

  @@map("job_applications")
}

// ==================== 6. TAXONOMY - Từ điển kỹ năng ====================

model SkillTaxonomy {
  skillId         String            @id @default(uuid()) @map("skill_id")
  skillName       String            @unique @map("skill_name")
  skillEmbedding  String?           @map("skill_embedding")
  category        String
  parentSkillId   String?           @map("parent_skill_id")
  aliases         String[]          @map("aliases")
  demandScore     Float             @default(0.0) @map("demand_score")

  parent          SkillTaxonomy?    @relation("SkillHierarchy", fields: [parentSkillId], references: [skillId])
  subSkills       SkillTaxonomy[]   @relation("SkillHierarchy")

  @@map("skill_taxonomy")
}

// ==================== 7. ANALYTICS - Log hành vi ====================

model CareerEvent {
  eventId           BigInt            @id @default(autoincrement()) @map("event_id")
  userId            String            @map("user_id")
  eventType         EventType         @map("event_type")
  jobId             String?           @map("job_id")
  searchQuery       String?           @map("search_query")
  searchFiltersJson Json?             @map("search_filters_json")
  clickPosition     Int?              @map("click_position")
  timeSpentSeconds  Int?              @map("time_spent_seconds")
  deviceType        String?           @map("device_type")
  createdAt         DateTime          @default(now()) @map("created_at")

  user              JobUser           @relation(fields: [userId], references: [userId])
  job               JobPosting?       @relation(fields: [jobId], references: [jobId])

  @@map("career_events")
}

// ==================== 8. PERMISSIONS - Phân quyền RBAC ====================

model Permission {
  permissionId String @id @default(uuid()) @map("permission_id")
  name         String @unique // "job:create", "user:read", "company:verify"
  description  String?
  resource     String // "job", "user", "company", "application"
  action       String // "create", "read", "update", "delete", "manage"

  userPermissions UserPermission[]

  @@map("permissions")
}

model UserPermission {
  userId       String   @map("user_id")
  permissionId String   @map("permission_id")
  grantedAt    DateTime @default(now()) @map("granted_at")

  user         User       @relation(fields: [userId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [permissionId])

  @@id([userId, permissionId])
  @@map("user_permissions")
}

// ==================== 9. NOTIFICATIONS - Thông báo ====================

enum NotificationType {
  application_status   // Trạng thái đơn ứng tuyển thay đổi
  new_application      // Có đơn ứng tuyển mới (cho recruiter)
  new_job_match        // Có tin tuyển dụng phù hợp (cho candidate)
  job_expiring         // Tin tuyển dụng sắp hết hạn
  system               // Thông báo hệ thống
}

model Notification {
  id          String           @id @default(uuid())
  userId      String           @map("user_id")
  title       String
  message     String
  type        NotificationType
  isRead      Boolean          @default(false) @map("is_read")
  relatedId   String?          @map("related_id") // jobId hoặc applicationId
  createdAt   DateTime         @default(now()) @map("created_at")

  user        User             @relation(fields: [userId], references: [id])

  @@map("notifications")
}

// ==================== 10. SAVED JOBS - Tin tuyển dụng đã lưu ====================

model SavedJob {
  id        String     @id @default(uuid())
  userId    String     @map("user_id")
  jobId     String     @map("job_id")
  savedAt   DateTime   @default(now()) @map("saved_at")

  user      User       @relation(fields: [userId], references: [id])
  job       JobPosting @relation(fields: [jobId], references: [jobId])

  @@unique([userId, jobId]) // Mỗi user chỉ lưu một tin một lần
  @@map("saved_jobs")
}

// ==================== 11. INTERVIEWS - Lịch phỏng vấn ====================

enum InterviewStatus {
  scheduled
  completed
  cancelled
  rescheduled
}

model Interview {
  id             String          @id @default(uuid())
  applicationId  String          @map("application_id")
  title          String          // Ví dụ: "Phỏng vấn vòng kỹ thuật"
  description    String?         @db.Text
  scheduledAt    DateTime        @map("scheduled_at")
  durationMinutes Int            @default(45) @map("duration_minutes")
  meetingLink    String?         @map("meeting_link") // Zoom, Google Meet...
  status         InterviewStatus @default(scheduled)
  notes          String?         @db.Text // Ghi chú từ recruiter
  feedback       String?         @db.Text // Phản hồi từ candidate
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  application    JobApplication  @relation(fields: [applicationId], references: [applicationId])

  @@map("interviews")
}

// ==================== 12. REVIEWS - Đánh giá công ty ====================

model CompanyReview {
  id           String   @id @default(uuid())
  companyId    String   @map("company_id")
  candidateId  String   @map("candidate_id")
  rating       Int      // Chấm điểm 1-5 sao
  reviewText   String   @db.Text @map("review_text")
  isAnonymous  Boolean  @default(false) @map("is_anonymous")
  createdAt    DateTime @default(now()) @map("created_at")

  company      Company  @relation(fields: [companyId], references: [companyId])
  candidate    User     @relation(fields: [candidateId], references: [id])

  @@unique([companyId, candidateId]) // Mỗi ứng viên chỉ được đánh giá một công ty 1 lần
  @@map("company_reviews")
}

// ==================== 13. SUBSCRIPTIONS - Đăng ký nhận tin ====================

model Subscription {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  skills      String[] // Kỹ năng đăng ký nhận tin (ví dụ: ["React", "Korean"])
  locations   String[] // Địa điểm mong muốn (ví dụ: ["Seoul", "Hồ Chí Minh"])
  topikLevel  TopikLevel @default(NONE) @map("topik_level") // Trình độ tiếng Hàn tối thiểu
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id])

  @@map("subscriptions")
}